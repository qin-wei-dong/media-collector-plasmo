{
  "name": "media-collector-plasmo",
  "displayName": "素材采集助手",
  "version": "2.1.1",
  "description": "一键采集小红书笔记图片和视频素材",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "test:release-scope": "node scripts/test-release-scope.mjs",
    "audit:a11y": "node scripts/a11y-audit.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "axe-core": "^4.12.1",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "manifest": {
    "action": {},
    "host_permissions": [
      "https://www.xiaohongshu.com/*"
    ],
    "permissions": [
      "storage",
      "downloads",
      "scripting",
      "contextMenus",
      "notifications",
      "tabs"
    ],
    "commands": {
      "collect_media": {
        "suggested_key": {
          "default": "Ctrl+Shift+S",
          "mac": "Command+Shift+S"
        },
        "description": "采集当前小红书笔记素材"
      }
    }
  }
}
